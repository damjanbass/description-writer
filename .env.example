# Korpus deployment environment template.
#
# Copy this to `.env` (git-ignored — see .gitignore) and fill in real
# values. Never commit `.env`. Every value below is a placeholder; none of
# these are real secrets.
#
#   cp .env.example .env
#
# docker-compose.yml (deploy/) loads this file for the app/worker/caddy
# services. Variable names below match exactly what the code reads via
# os.environ — see the mapping table in doc/deploy.md / the task report
# for the source line of each one.

# -----------------------------------------------------------------------
# Caddy (deploy/Caddyfile) — NOT read by Django, consumed by Caddy itself
# -----------------------------------------------------------------------
# Public domain the site is served on; also the name Caddy requests a TLS
# certificate for via auto-HTTPS.
KORPUS_DOMAIN=korpus.rs
# Contact email Let's Encrypt uses for expiry/problem notices.
KORPUS_ACME_EMAIL=damjan9494@gmail.com

# -----------------------------------------------------------------------
# Django core (web/config/settings/prod.py, web/config/settings/base.py)
# -----------------------------------------------------------------------
# Which settings module manage.py loads. manage.py defaults to
# config.settings.dev if this is unset, so set it explicitly here — it's
# read by every `docker compose exec app python web/manage.py ...` call,
# not just the gunicorn process (wsgi.py already defaults to prod).
DJANGO_SETTINGS_MODULE=config.settings.prod

# Django's signing/session secret key. REQUIRED in production; boot fails
# without it. Must be >=50 characters with >=5 distinct characters.
# Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
KORPUS_SECRET_KEY=changeme-generate-a-real-64-byte-token-with-the-command-above

# Comma-separated list of hostnames Django will accept as the Host header.
KORPUS_ALLOWED_HOSTS=korpus.rs,www.korpus.rs

# Comma-separated list of origins (with scheme) trusted for CSRF-bearing
# cross-origin POSTs (Django admin, forms, etc.).
KORPUS_CSRF_TRUSTED_ORIGINS=https://korpus.rs,https://www.korpus.rs

# -----------------------------------------------------------------------
# Postgres (web/config/settings/prod.py DATABASES)
# -----------------------------------------------------------------------
POSTGRES_DB=korpus
POSTGRES_USER=korpus
POSTGRES_PASSWORD=changeme-strong-random-password
# "db" is the docker-compose service name for the Postgres container —
# leave as-is unless you rename that service.
POSTGRES_HOST=db
POSTGRES_PORT=5432

# -----------------------------------------------------------------------
# Credential encryption at rest (web/connections/crypto.py)
# -----------------------------------------------------------------------
# Encrypts connector (e.g. WooCommerce) credentials before they're stored
# in the database. REQUIRED in production (no fallback outside DEBUG).
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Rotating this key makes all previously stored connector credentials
# undecryptable — re-enter them after rotation.
KORPUS_FERNET_KEY=changeme-generate-a-real-fernet-key-with-the-command-above

# -----------------------------------------------------------------------
# LLM provider (pipeline/generation.py AnthropicProvider — Anthropic SDK's
# own default credential resolution, not a Django setting)
# -----------------------------------------------------------------------
ANTHROPIC_API_KEY=changeme-anthropic-api-key

# -----------------------------------------------------------------------
# Media storage (web/config/settings/base.py MEDIA_ROOT)
# -----------------------------------------------------------------------
# Where uploaded catalogs and generated batch outputs are written. Point
# this at a path backed by a persistent volume (see deploy/docker-compose.yml)
# so uploads survive container recreation. Never served directly by Caddy —
# see the /media/* note in deploy/Caddyfile.
KORPUS_MEDIA_ROOT=/data/media

# -----------------------------------------------------------------------
# Outbound email (web/config/settings/prod.py) — used for password resets
# and lead notifications
# -----------------------------------------------------------------------
KORPUS_EMAIL_HOST=smtp.example.com
KORPUS_EMAIL_PORT=587
KORPUS_EMAIL_HOST_USER=changeme-smtp-username
KORPUS_EMAIL_HOST_PASSWORD=changeme-smtp-password
KORPUS_EMAIL_USE_TLS=true
KORPUS_DEFAULT_FROM_EMAIL=no-reply@korpus.rs

# Where the static landing page's contact-form leads get emailed
# (web/leads/views.py). Defaults to damjan9494@gmail.com in code if unset.
LEAD_NOTIFY_EMAIL=damjan9494@gmail.com

# -----------------------------------------------------------------------
# WooCommerce CLI connector (pipeline/cli.py) — CLI publishing only, not
# needed by the web app. Uncomment only on a machine that runs the
# `pipeline` publish CLI directly against a WooCommerce store.
# -----------------------------------------------------------------------
# KORPUS_CONSUMER_KEY=changeme-woocommerce-consumer-key
# KORPUS_CONSUMER_SECRET=changeme-woocommerce-consumer-secret
